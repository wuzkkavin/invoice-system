{
  "nodes": [
    {
      "id": "file:config_manager.py",
      "type": "file",
      "name": "設定檔管理",
      "filePath": "config_manager.py",
      "summary": "讀寫 config.json 設定檔，支援 dist/ 與專案根目錄雙路徑查找，自動載入 ~/.openai.env 環境變數，提供 get_api_key() 供其他模組取得 API 金鑰",
      "tags": ["設定", "config.json", "API金鑰", "環境變數"],
      "complexity": "simple"
    },
    {
      "id": "function:config_manager.py:_get_config_paths",
      "type": "function",
      "name": "_get_config_paths",
      "filePath": "config_manager.py",
      "summary": "依 frozen 狀態決定 config.json 查找路徑：執行檔目錄（dist/）與專案根目錄",
      "tags": ["路徑", "設定", "PyInstaller"],
      "complexity": "simple"
    },
    {
      "id": "function:config_manager.py:load_config",
      "type": "function",
      "name": "load_config",
      "filePath": "config_manager.py",
      "summary": "依序嘗試讀取 config.json，合併 DEFAULT_CONFIG 預設值，所有路徑失敗時回傳空字串設定",
      "tags": ["讀取", "config.json", "JSON解析"],
      "complexity": "simple"
    },
    {
      "id": "function:config_manager.py:save_config",
      "type": "function",
      "name": "save_config",
      "filePath": "config_manager.py",
      "summary": "將設定寫入 config.json，優先寫入第一個存在的路徑，否則寫入專案根目錄",
      "tags": ["寫入", "config.json", "JSON序列化"],
      "complexity": "simple"
    },
    {
      "id": "function:config_manager.py:_load_env_file",
      "type": "function",
      "name": "_load_env_file",
      "filePath": "config_manager.py",
      "summary": "從 ~/.openai.env 讀取環境變數設定，在模組載入時自動呼叫",
      "tags": ["環境變數", ".env", "自動載入"],
      "complexity": "simple"
    },
    {
      "id": "function:config_manager.py:get_api_key",
      "type": "function",
      "name": "get_api_key",
      "filePath": "config_manager.py",
      "summary": "依 provider 名稱先從 config.json 取得 API 金鑰，若無則 fallback 至環境變數",
      "tags": ["API金鑰", "讀取", "fallback"],
      "complexity": "simple"
    },
    {
      "id": "file:db_manager.py",
      "type": "file",
      "name": "資料庫管理",
      "filePath": "db_manager.py",
      "summary": "SQLite 資料庫完整 CRUD：定義 invoices 表格、新增/更新/刪除/查詢/搜尋發票記錄，支援圖片檔案清理，模組載入時自動初始化",
      "tags": ["資料庫", "SQLite", "CRUD", "發票", "初始化"],
      "complexity": "moderate"
    },
    {
      "id": "function:db_manager.py:_get_base_dir",
      "type": "function",
      "name": "_get_base_dir",
      "filePath": "db_manager.py",
      "summary": "取得應用程式根目錄，支援 PyInstaller 打包模式",
      "tags": ["路徑", "輔助函式", "PyInstaller"],
      "complexity": "simple"
    },
    {
      "id": "function:db_manager.py:get_connection",
      "type": "function",
      "name": "get_connection",
      "filePath": "db_manager.py",
      "summary": "建立 SQLite 連線，設定 row_factory 為 sqlite3.Row，所有 CRUD 函式的共用底層",
      "tags": ["SQLite", "連線", "資料庫"],
      "complexity": "simple"
    },
    {
      "id": "function:db_manager.py:init_db",
      "type": "function",
      "name": "init_db",
      "filePath": "db_manager.py",
      "summary": "建立 images 目錄與 invoices 資料表（含 id/invoice_no/date/seller/seller_tax_id/product/amount/tax/image_path/created_at 欄位），模組載入時自動執行",
      "tags": ["初始化", "資料表建立", "目錄建立"],
      "complexity": "simple"
    },
    {
      "id": "function:db_manager.py:insert_invoice",
      "type": "function",
      "name": "insert_invoice",
      "filePath": "db_manager.py",
      "summary": "新增發票記錄，回傳自動產生的 invoice_id",
      "tags": ["新增", "INSERT", "資料庫寫入"],
      "complexity": "simple"
    },
    {
      "id": "function:db_manager.py:update_invoice",
      "type": "function",
      "name": "update_invoice",
      "filePath": "db_manager.py",
      "summary": "更新發票記錄，依是否有新圖片決定是否一併更新 image_path 欄位",
      "tags": ["更新", "UPDATE", "資料庫寫入"],
      "complexity": "simple"
    },
    {
      "id": "function:db_manager.py:delete_invoice",
      "type": "function",
      "name": "delete_invoice",
      "filePath": "db_manager.py",
      "summary": "刪除發票記錄前先取得圖片路徑，一併刪除關聯的圖片檔案",
      "tags": ["刪除", "DELETE", "資料庫", "圖片清理"],
      "complexity": "simple"
    },
    {
      "id": "function:db_manager.py:search_invoices",
      "type": "function",
      "name": "search_invoices",
      "filePath": "db_manager.py",
      "summary": "多條件模糊搜尋：發票號碼/賣方/品名/統編/金額區間/日期區間，回傳 dict 列表",
      "tags": ["搜尋", "SELECT", "模糊查詢", "多條件"],
      "complexity": "moderate"
    },
    {
      "id": "function:db_manager.py:get_all_invoices",
      "type": "function",
      "name": "get_all_invoices",
      "filePath": "db_manager.py",
      "summary": "取得全部發票記錄，依日期與 ID 遞減排序",
      "tags": ["查詢", "SELECT", "全部資料"],
      "complexity": "simple"
    },
    {
      "id": "function:db_manager.py:get_invoice_by_id",
      "type": "function",
      "name": "get_invoice_by_id",
      "filePath": "db_manager.py",
      "summary": "依 invoice_id 取得單筆發票記錄，不存在則回傳 None",
      "tags": ["查詢", "SELECT", "單筆資料"],
      "complexity": "simple"
    },
    {
      "id": "file:main.py",
      "type": "file",
      "name": "程式入口",
      "filePath": "main.py",
      "summary": "系統啟動點，設定 BASE_DIR 與 sys.path，匯入 db_manager 自動初始化資料庫，建立 MainWindow 主視窗並進入 Tkinter 事件循環",
      "tags": ["入口", "啟動", "Tkinter", "主視窗"],
      "complexity": "simple"
    },
    {
      "id": "function:main.py:main",
      "type": "function",
      "name": "main",
